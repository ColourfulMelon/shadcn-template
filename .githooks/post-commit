#!/bin/sh
# Post-commit: run Biome lint on the files this commit touched (mirrors CI's `pnpm lint`).
#
# post-commit runs AFTER the commit is created, so it can only *report* — it cannot block
# or rewrite the commit. To fix lint issues:  pnpm check:fix  then  git commit --amend --no-edit
# For a blocking gate, add a pre-commit hook that runs the same check.
#
# Lint only (not `biome check`) so the hook matches what CI enforces and stays quiet on the
# template's not-yet-formatted files. Run `pnpm format` if you want to normalize formatting.
#
# Enabled via `core.hooksPath=.githooks`, set by the "prepare" script on `pnpm install`.

root="$(git rev-parse --show-toplevel)"
biome="$root/node_modules/.bin/biome"

if [ ! -x "$biome" ]; then
  echo "post-commit: Biome not installed — run 'pnpm install'. Skipping."
  exit 0
fi

# Added/copied/modified files in the new commit, limited to types Biome handles.
files=""
for f in $(git diff-tree --no-commit-id --name-only --diff-filter=ACMR -r HEAD); do
  case "$f" in
    *.ts | *.tsx | *.js | *.jsx | *.mjs | *.cjs | *.json | *.jsonc)
      [ -f "$root/$f" ] && files="$files $root/$f"
      ;;
  esac
done

[ -z "$files" ] && exit 0

echo "▶ Biome post-commit lint…"
if ! "$biome" lint --reporter=summary $files; then
  echo "⚠ Biome lint flagged the last commit. Fix with: pnpm check:fix (then git commit --amend --no-edit)"
fi
exit 0
